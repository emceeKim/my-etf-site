# =====================================================================
# my-etf-site 환경변수 가이드 (.env.local 로 복사 후 실제 값 입력)
# =====================================================================
# ⚠️ 이 파일은 안전하게 git에 커밋됩니다 (실제 값은 비어 있어야 함)
# ⚠️ 실제 값이 든 .env.local 은 절대 커밋 금지 (.gitignore 가 차단함)
# =====================================================================

# ---------- 브라우저 노출 OK (NEXT_PUBLIC_ 접두사) ----------
# anon key 는 RLS 정책이 켜져 있으면 공개되어도 안전합니다.
# 반드시 supabase/rls_policies.sql 을 실행한 뒤에만 노출하세요.
NEXT_PUBLIC_SUPABASE_URL=https://yoqqgugokrmecmkelycs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...여기에_anon_key_입력

# ---------- 서버 전용 (절대 NEXT_PUBLIC_ 접두사 붙이지 말 것) ----------
# service_role 키는 RLS 를 우회하는 만능 키입니다.
# Python 수집 스크립트(collect_etf.py)에서만 사용. 브라우저 절대 노출 금지.
SUPABASE_SECRET_KEY=eyJhbGciOi...여기에_service_role_key_입력

# ---------- 추후 X 자동화/Claude API 추가 시 ----------
# CLAUDE_API_KEY=sk-ant-...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# =====================================================================
# Vercel 배포 시 환경변수 설정 위치
# =====================================================================
# Vercel Dashboard → Project → Settings → Environment Variables
#   - Production / Preview / Development 환경별로 분리해 입력
#   - SUPABASE_SECRET_KEY 는 Production 에서만 활성화 권장
# =====================================================================
